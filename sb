#!/bin/sh

set -eu

PATH=${SB_PATH:-/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin}
export PATH
umask 077

LIB_DIR=${SB_LIB_DIR:-/usr/local/lib/sb-manager}
# shellcheck source=lib/common.sh
. "$LIB_DIR/common.sh"
# shellcheck source=lib/platform.sh
. "$LIB_DIR/platform.sh"
# shellcheck source=lib/protocols.sh
. "$LIB_DIR/protocols.sh"
. "$LIB_DIR/protocols_extended.sh"
. "$LIB_DIR/caddy.sh"
. "$LIB_DIR/operations.sh"
. "$LIB_DIR/output.sh"
. "$LIB_DIR/migrate.sh"
. "$LIB_DIR/forward.sh"

VERSION=3.2.1

usage() {
  cat <<'EOF'
Usage: sb COMMAND [arguments]

Node commands:
  sb add <anytls|ss2022|vless-reality|socks5> [options]
  sb change NAME [--listen-port PORT] [--public-address HOST] [--public-port PORT]
  sb list
  sb info NAME
  sb url NAME
  sb qr NAME
  sb delete NAME [--yes]

Service commands:
  sb start | stop | restart | status | check | log

Maintenance:
  sb backup [ARCHIVE]
  sb restore ARCHIVE
  sb update
  sb uninstall [--purge] [--remove-core] [--yes]

NAT example:
  sb add anytls --name tw --listen-port 30009 \
    --public-address 23.134.212.11 --public-port 64491
EOF
}

restart_and_verify() {
  previous_active=0
  service_active && previous_active=1 || true
  caddy_sync
  if [ "$previous_active" -eq 1 ]; then service_restart; else service_enable; service_start; fi
  service_active || return 1
}

commit_node_change() {
  name=$1
  staged_config=$2
  staged_meta=$3
  staged_cert_dir=${4:-}
  operation=$5

if [ "$operation" = delete ] || [ "$operation" = disable ]; then candidate=$(build_candidate_dir "$name" ""); else candidate=$(build_candidate_dir "$name" "$staged_config"); fi
  if [ -n "$staged_cert_dir" ] && [ -d "$staged_cert_dir" ]; then
    jq --arg cert "$staged_cert_dir/cert.pem" --arg key "$staged_cert_dir/key.pem" \
      '(.inbounds[0].tls.certificate_path)=$cert | (.inbounds[0].tls.key_path)=$key' \
      "$candidate/$name.json" >"$candidate/$name.validate.json"
    mv "$candidate/$name.validate.json" "$candidate/$name.json"
  fi
  validate_complete_config "$candidate"
  backup=$(mktemp -d /tmp/sb-rollback.XXXXXX)
  old_config=$(node_config_file "$name")
  old_meta=$(node_meta_file "$name")
  [ ! -f "$old_config" ] || cp "$old_config" "$backup/config.json"
  [ ! -f "$old_meta" ] || cp "$old_meta" "$backup/meta.json"
  [ ! -d "$SB_CERT_DIR/$name" ] || cp -R "$SB_CERT_DIR/$name" "$backup/certs"

  if [ "$operation" = delete ]; then
    rm -f "$old_config" "$old_meta"
    rm -rf "$SB_CERT_DIR/$name"
  elif [ "$operation" = disable ]; then
    rm -f "$old_config"
    install -m 0600 "$staged_meta" "$old_meta"
  else
    install -m 0640 "$staged_config" "$old_config"
    install -m 0600 "$staged_meta" "$old_meta"
    if [ -n "$staged_cert_dir" ] && [ -d "$staged_cert_dir" ]; then
      rm -rf "$SB_CERT_DIR/$name"
      install -d -m 0750 "$SB_CERT_DIR/$name"
      cp "$staged_cert_dir"/* "$SB_CERT_DIR/$name/"
      chmod 0644 "$SB_CERT_DIR/$name/cert.pem"
      chmod 0640 "$SB_CERT_DIR/$name/key.pem"
    fi
  fi

  if getent group sing-box >/dev/null 2>&1; then
    chown -R root:sing-box "$SB_CONF_DIR" "$SB_CERT_DIR"
  fi

  if ! restart_and_verify; then
    rm -f "$old_config" "$old_meta"
    rm -rf "$SB_CERT_DIR/$name"
    [ ! -f "$backup/config.json" ] || cp "$backup/config.json" "$old_config"
    [ ! -f "$backup/meta.json" ] || cp "$backup/meta.json" "$old_meta"
    [ ! -d "$backup/certs" ] || cp -R "$backup/certs" "$SB_CERT_DIR/$name"
    service_restart >/dev/null 2>&1 || true
    rm -rf "$candidate" "$backup"
    die 'service verification failed; previous node state restored'
  fi
  rm -rf "$candidate" "$backup"
}

command_add() {
  [ "$#" -ge 1 ] || die 'protocol is required'
  protocol=$1
  shift
  case "$protocol" in anytls|ss2022|vless-reality|socks5|hysteria2|tuic|trojan|vmess|vless-tls) ;; *) die 'unsupported protocol' ;; esac

  name=
  listen_address=0.0.0.0
  listen_port=
  public_address=$(manager_server_address)
  public_port=
  username=default
  password=
  ss_method=2022-blake3-aes-128-gcm
  reality_server=www.microsoft.com
  reality_port=443
  cert_source=
  key_source=
  transport=tcp
  path=/proxy
  host=
  tls_mode=
  acme_email=
  obfs_password=

  while [ "$#" -gt 0 ]; do
    [ "$#" -ge 2 ] || die "add option requires a value: $1"
    case "$1" in
      --name) name=$2; shift 2 ;;
      --listen-address|--listen) listen_address=$2; shift 2 ;;
      --listen-port|--port) listen_port=$2; shift 2 ;;
      --public-address|--server-address) public_address=$2; shift 2 ;;
      --public-port) public_port=$2; shift 2 ;;
      --username) username=$2; shift 2 ;;
      --password) password=$2; shift 2 ;;
      --ss-method) ss_method=$2; shift 2 ;;
      --reality-server) reality_server=$2; shift 2 ;;
      --reality-port) reality_port=$2; shift 2 ;;
      --cert) cert_source=$2; shift 2 ;;
      --key) key_source=$2; shift 2 ;;
      --transport) transport=$2; shift 2 ;;
      --path) path=$2; shift 2 ;;
      --host) host=$2; shift 2 ;;
      --tls-mode) tls_mode=$2; shift 2 ;;
      --acme-email) acme_email=$2; shift 2 ;;
      --obfs-password) obfs_password=$2; shift 2 ;;
      *) die "unknown add option: $1" ;;
    esac
  done

  [ -n "$listen_port" ] || listen_port=$(protocol_default_port_all "$protocol")
  [ -n "$host" ] || host=$public_address
  [ -n "$public_port" ] || public_port=$listen_port
  [ -n "$name" ] || name="$protocol-$listen_port"
  validate_name "$name" || die 'invalid node name'
  validate_host "$public_address" || die 'invalid public address'
  is_ipv4 "$listen_address" || die 'listen address must be IPv4'
  validate_port "$listen_port" || die 'invalid listen port'
  validate_port "$public_port" || die 'invalid public port'
  validate_port "$reality_port" || die 'invalid REALITY port'
  validate_host "$reality_server" || die 'invalid REALITY server'
  node_exists "$name" && die "node already exists: $name"
  port_in_metadata "$listen_port" '' && die "listen port already managed: $listen_port"

  work=$(mktemp -d /tmp/sb-add.XXXXXX)
  meta=$work/meta.json
  config=$work/config.json
  cert_stage=$work/certs
  protocol_generate "$meta" "$protocol" "$name" "$listen_address" "$listen_port" \
    "$public_address" "$public_port" "$username" "$password" "$ss_method" \
    "$reality_server" "$reality_port" "$cert_source" "$key_source" "$cert_stage" \
    "$transport" "$path" "$host" "$tls_mode" "$acme_email" "$obfs_password"
  protocol_render "$meta" "$config"
  commit_node_change "$name" "$config" "$meta" "$cert_stage" add
  rm -rf "$work"
  info "节点已添加: $name"
  say '节点导入链接（包含密码，请妥善保管）:'
  command_url "$name"
}

command_list() {
  printf '%-24s %-16s %-9s %-18s %-18s\n' 节点名称 协议 状态 内部监听 公网地址
  for name in $(list_node_names); do
    meta=$(node_meta_file "$name")
    printf '%-24s %-16s %-9s %-18s %-18s\n' \
      "$name" "$(jq -r '.protocol' "$meta")" "$(jq -r 'if has("enabled") then .enabled else true end' "$meta")" \
      "$(jq -r '.listen.address+":"+(.listen.port|tostring)' "$meta")" \
      "$(jq -r '.public.address+":"+(.public.port|tostring)' "$meta")"
  done
}

command_info() {
  [ "$#" -ge 1 ] || die 'node name is required'
  info_name=$1; shift
  info_show=0
  [ "${1:-}" != --show-secrets ] || info_show=1
  node_exists "$info_name" || die "node not found: $info_name"
  info_meta=$(node_meta_file "$info_name")
  if [ "$info_show" -eq 1 ]; then
    jq . "$info_meta"
    say '分享链接:'
    protocol_share_uri "$info_meta"
  else
    jq 'del(.credentials.password,.reality.private_key) | if .credentials.uuid then .credentials.uuid="***" else . end | if .reality.public_key then .reality.public_key="***" else . end' "$info_meta"
    say '使用 `sb info 节点名 --show-secrets` 或 `sb url 节点名` 查看完整凭据。'
  fi
}

command_url() {
  [ "$#" -eq 1 ] || die 'node name is required'
  node_exists "$1" || die "node not found: $1"
  protocol_share_uri "$(node_meta_file "$1")"
}

command_qr() {
  url=$(command_url "$@")
  if command -v qrencode >/dev/null 2>&1; then qrencode -t ANSIUTF8 "$url"; else say "$url"; warn '未安装 qrencode，已直接输出链接'; fi
}

command_delete() {
  [ "$#" -ge 1 ] || die 'node name is required'
  name=$1
  shift
  yes=0
  [ "${1:-}" != --yes ] || yes=1
  node_exists "$name" || die "node not found: $name"
  [ "$yes" -eq 1 ] || confirm "确定删除节点 $name 吗？" || return 0
  empty=$(mktemp /tmp/sb-empty.XXXXXX)
  : >"$empty"
  commit_node_change "$name" "$empty" "$empty" '' delete
  rm -f "$empty"
  info "节点已删除: $name"
}

command_change() {
  [ "$#" -ge 1 ] || die 'node name is required'
  name=$1
  shift
  node_exists "$name" || die "node not found: $name"
  source_meta=$(node_meta_file "$name")
  listen_port=$(jq -r '.listen.port' "$source_meta")
  public_address=$(jq -r '.public.address' "$source_meta")
  public_port=$(jq -r '.public.port' "$source_meta")
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --listen-port|--port) listen_port=$2; shift 2 ;;
      --public-address|--server-address) public_address=$2; shift 2 ;;
      --public-port) public_port=$2; shift 2 ;;
      *) die "unknown change option: $1" ;;
    esac
  done
  validate_port "$listen_port" || die 'invalid listen port'
  validate_port "$public_port" || die 'invalid public port'
  validate_host "$public_address" || die 'invalid public address'
  port_in_metadata "$listen_port" "$name" && die "listen port already managed: $listen_port"
  work=$(mktemp -d /tmp/sb-change.XXXXXX)
  jq --argjson listen_port "$listen_port" --arg public_address "$public_address" \
    --argjson public_port "$public_port" --arg updated_at "$(timestamp)" \
    '.listen.port=$listen_port | .public.address=$public_address | .public.port=$public_port | .updated_at=$updated_at' \
    "$source_meta" >"$work/meta.json"
  protocol_render "$work/meta.json" "$work/config.json"
cert_stage=
  protocol=$(jq -r '.protocol' "$source_meta")
  old_public_address=$(jq -r '.public.address' "$source_meta")
  tls_mode=$(jq -r '.tls.mode // empty' "$source_meta")
  if [ "$protocol" = anytls ] && [ "$tls_mode" = self-signed ] && [ "$old_public_address" != "$public_address" ]; then
    cert_stage="$work/certs"
    install -d -m 0700 "$cert_stage"
    if is_ipv4 "$public_address"; then san="IP:$public_address"; else san="DNS:$public_address"; fi
    openssl ecparam -genkey -name prime256v1 -out "$cert_stage/key.pem"
    openssl req -new -x509 -key "$cert_stage/key.pem" -sha256 -days 3650 \
      -out "$cert_stage/cert.pem" -subj "/CN=$public_address" -addext "subjectAltName=$san"
    chmod 0640 "$cert_stage/key.pem"
    chmod 0644 "$cert_stage/cert.pem"
  fi
  commit_node_change "$name" "$work/config.json" "$work/meta.json" "$cert_stage" change
  rm -rf "$work"
  info "节点已修改: $name"
  command_info "$name"
}

command_check() {
  sing-box check -c "$SB_BASE_CONFIG" -C "$SB_CONF_DIR"
}

command_backup() {
  archive=${1:-/root/sb-backup-$(timestamp).tar.gz}
  case "$archive" in /*) ;; *) archive="$(pwd)/$archive" ;; esac
  tar -C / -czf "$archive" "${SB_HOME#/}" "${SB_RUNTIME_DIR#/}" usr/local/bin/sb
  chmod 0600 "$archive"
  sha256sum "$archive" >"$archive.sha256"
  chmod 0600 "$archive.sha256"
  info "Backup created: $archive"
}

command_restore() {
  [ "$#" -eq 1 ] || die 'backup archive is required'
  archive=$1
  [ -r "$archive" ] || die 'backup archive is not readable'
  tar -tzf "$archive" | grep -Eq '(^/|(^|/)\.\.(/|$))' && die 'unsafe backup archive paths'
  backup_before=/root/sb-before-restore-$(timestamp).tar.gz
  command_backup "$backup_before"
  tar -C / -xzf "$archive"
  command_check || { warn "restore validation failed; restoring $backup_before"; tar -C / -xzf "$backup_before"; die 'restore failed'; }
  restart_and_verify
  info 'Backup restored.'
}

command_update() {
  tmp=$(mktemp -d /tmp/sb-update.XXXXXX)
  curl -fsSL https://github.com/kukumi1/sing-box/archive/refs/heads/main.tar.gz -o "$tmp/source.tar.gz"
  tar -C "$tmp" -xzf "$tmp/source.tar.gz"
  source_dir=$(find "$tmp" -mindepth 1 -maxdepth 1 -type d | head -n 1)
  sh "$source_dir/install.sh" --upgrade
  rm -rf "$tmp"
  info 'Manager updated.'
}

command_uninstall() {
  purge=0
  remove_core=0
  yes=0
  while [ "$#" -gt 0 ]; do
    case "$1" in --purge) purge=1 ;; --remove-core) remove_core=1 ;; --yes) yes=1 ;; *) die "unknown uninstall option: $1" ;; esac
    shift
  done
  [ "$yes" -eq 1 ] || confirm 'Uninstall sb manager?' || return 0
  service_active && service_stop || true
  service_enabled && service_disable || true
  forward_uninstall
  if [ "$SB_PLATFORM" = alpine ]; then rm -f /etc/init.d/sb-sing-box; else rm -f /etc/systemd/system/sb-sing-box.service; systemctl daemon-reload; fi
  rm -f /usr/local/bin/sb
  rm -rf "$SB_RUNTIME_DIR"
  [ "$purge" -eq 0 ] || rm -rf "$SB_HOME"
  if [ "$remove_core" -eq 1 ]; then
    if [ "$SB_PLATFORM" = alpine ]; then apk del sing-box sing-box-openrc || true; else apt-get remove -y sing-box || true; fi
  fi
  info 'sb 管理器已卸载'
}

interactive_add_node() {
  cat <<'EOF'

请选择节点协议：
1) AnyTLS
2) Shadowsocks 2022
3) VLESS + REALITY
4) SOCKS5
5) Hysteria2
6) TUIC
7) Trojan
8) VMess
9) VLESS TLS
0) 返回主菜单
EOF
  printf '请输入协议编号: '
  read -r protocol_choice
  case "$protocol_choice" in
    1) menu_protocol=anytls ;;
    2) menu_protocol=ss2022 ;;
    3) menu_protocol=vless-reality ;;
    4) menu_protocol=socks5 ;;
    5) menu_protocol=hysteria2 ;;
    6) menu_protocol=tuic ;;
    7) menu_protocol=trojan ;;
    8) menu_protocol=vmess ;;
    9) menu_protocol=vless-tls ;;
    0) return 0 ;;
    *) warn '无效的协议编号'; return 1 ;;
  esac

  printf '节点名称（留空则自动生成）: '
  read -r menu_name
  printf '内部监听端口（留空则使用默认端口）: '
  read -r menu_listen_port
  printf '客户端连接的公网 IP 或域名（留空使用安装时设置）: '
  read -r menu_public_address
  printf 'NAT 映射后的公网端口（留空则与内部端口相同）: '
  read -r menu_public_port

  set -- "$menu_protocol"
  [ -z "$menu_name" ] || set -- "$@" --name "$menu_name"
  [ -z "$menu_listen_port" ] || set -- "$@" --listen-port "$menu_listen_port"
  [ -z "$menu_public_address" ] || set -- "$@" --public-address "$menu_public_address"
  [ -z "$menu_public_port" ] || set -- "$@" --public-port "$menu_public_port"
  command_add "$@"
}

interactive_select_node() {
  menu_nodes=$(list_node_names)
  if [ -z "$menu_nodes" ]; then
    warn '当前没有已创建的节点'
    return 1
  fi

  say ''
  say '请选择节点：'
  menu_index=1
  for menu_node in $menu_nodes; do
    menu_meta=$(node_meta_file "$menu_node")
    menu_protocol=$(jq -r '.protocol' "$menu_meta")
    menu_public=$(jq -r '.public.address+":"+(.public.port|tostring)' "$menu_meta")
    printf '%s) %s  [%s]  %s\n' "$menu_index" "$menu_node" "$menu_protocol" "$menu_public"
    menu_index=$((menu_index + 1))
  done
  say '0) 返回主菜单'
  printf '请输入节点序号: '
  read -r menu_selection
  [ "$menu_selection" != 0 ] || return 1
  case "$menu_selection" in ''|*[!0-9]*) warn '无效的节点序号'; return 1 ;; esac

  menu_index=1
  menu_selected_node=
  for menu_node in $menu_nodes; do
    if [ "$menu_index" -eq "$menu_selection" ]; then
      menu_selected_node=$menu_node
      break
    fi
    menu_index=$((menu_index + 1))
  done
  [ -n "$menu_selected_node" ] || { warn '节点序号不存在'; return 1; }
  return 0
}

interactive_select_forward() {
  menu_forward_names=$(forward_list_names)
  if [ -z "$menu_forward_names" ]; then
    warn '当前没有端口转发规则'
    return 1
  fi
  say ''
  say '请选择端口转发规则：'
  menu_forward_index=1
  for menu_forward_name in $menu_forward_names; do
    menu_forward_file=$(forward_config_file "$menu_forward_name")
    menu_forward_listen=$(jq -r '.listen_port' "$menu_forward_file")
    menu_forward_target=$(jq -r '.target.host+":"+(.target.port|tostring)' "$menu_forward_file")
    menu_forward_protocol=$(jq -r '.protocols|join("+")' "$menu_forward_file")
    printf '%s) %s  [%s]  %s -> %s\n' "$menu_forward_index" "$menu_forward_name" "$menu_forward_protocol" "$menu_forward_listen" "$menu_forward_target"
    menu_forward_index=$((menu_forward_index + 1))
  done
  say '0) 返回'
  printf '请输入规则序号: '
  read -r menu_forward_selection
  [ "$menu_forward_selection" != 0 ] || return 1
  case "$menu_forward_selection" in ''|*[!0-9]*) warn '无效的规则序号'; return 1 ;; esac
  menu_forward_index=1
  menu_selected_forward=
  for menu_forward_name in $menu_forward_names; do
    if [ "$menu_forward_index" -eq "$menu_forward_selection" ]; then menu_selected_forward=$menu_forward_name; break; fi
    menu_forward_index=$((menu_forward_index + 1))
  done
  [ -n "$menu_selected_forward" ] || { warn '规则序号不存在'; return 1; }
}

interactive_forward_menu() {
  while :; do
    cat <<'EOF'

iptables 动态端口转发
1) 添加转发规则
2) 查看转发规则
3) 启用转发规则
4) 禁用转发规则
5) 删除转发规则
6) 立即解析域名并同步
7) 查看 iptables 规则状态
0) 返回主菜单
EOF
    printf '请输入选项编号: '
    read -r forward_choice
    case "$forward_choice" in
      1)
        printf '规则名称（留空自动生成）: '; read -r forward_name
        printf '本机内部监听端口: '; read -r forward_listen
        printf '目标域名或 IPv4: '; read -r forward_host
        printf '目标端口（留空与本机端口相同）: '; read -r forward_target
        printf '协议 tcp/udp/both（留空默认 both）: '; read -r forward_protocol
        set -- --listen-port "$forward_listen" --target-host "$forward_host" --protocol "${forward_protocol:-both}"
        [ -z "$forward_name" ] || set -- "$@" --name "$forward_name"
        [ -z "$forward_target" ] || set -- "$@" --target-port "$forward_target"
        command_forward add "$@"
        ;;
      2) command_forward list ;;
      3) if interactive_select_forward; then command_forward enable "$menu_selected_forward"; fi ;;
      4) if interactive_select_forward; then command_forward disable "$menu_selected_forward"; fi ;;
      5) if interactive_select_forward && confirm "确定删除转发规则 $menu_selected_forward 吗？"; then command_forward delete "$menu_selected_forward"; fi ;;
      6) command_forward sync ;;
      7) command_forward status ;;
      0) return 0 ;;
      *) warn '无效的选项，请重新输入' ;;
    esac
  done
}

interactive_menu() {
  while :; do
    cat <<'EOF'

sb 中文管理菜单
1) 添加节点
2) 查看节点列表
3) 查看节点详细信息
4) 获取节点导入链接
5) 显示节点二维码
6) 修改节点地址或端口
7) 启用节点
8) 禁用节点
9) 重新生成节点密码或密钥
10) 删除节点
11) 查看服务状态
12) 重启服务
13) 创建备份
14) 恢复备份
