      0) return 0 ;;
      *) warn '无效的选项，请重新输入' ;;
    esac
  done
}

. "$LIB_DIR/output.sh"
. "$LIB_DIR/change.sh"
. "$LIB_DIR/maintenance.sh"

require_root
require_command jq
require_command sing-box
detect_platform
case "${1:-}:${2:-}" in
  forward:sync|forward:install-scheduler) ;;
  *) acquire_lock ;;
esac

[ "$#" -gt 0 ] || { interactive_menu; exit 0; }
command=$1
shift
case "$command" in
  add) command_add "$@" ;;
  forward) command_forward "$@" ;;
  migrate) command_migrate "$@" ;;
  enable) command_enable "$@" ;;
  disable) command_disable "$@" ;;
  rotate) command_rotate "$@" ;;
  export) command_export "$@" ;;
  client) command_client "$@" ;;
  snapshot) command_snapshot "$@" ;;
  rollback) command_rollback_release "$@" ;;
  manager-rollback) command_manager_rollback ;;
  core) command_core "$@" ;;
  doctor) command_doctor "$@" ;;
  bbr) command_bbr "$@" ;;
  dns) command_dns "$@" ;;
  caddy) case "${1:-status}" in sync) caddy_sync ;; status) caddy_status ;; log) caddy_logs "${2:-100}" ;; *) die "usage: sb caddy sync|status|log" ;; esac ;;
  change) command_change "$@" ;;
  list|ls) command_list ;;
  info) command_info "$@" ;;
  url) command_url "$@" ;;
  qr) command_qr "$@" ;;
  delete|del|rm) command_delete "$@" ;;
  start) service_enable; service_start ;;
  stop) service_stop ;;
  restart) service_restart ;;
  status) service_status ;;
  check) command_check ;;
  log|logs) service_logs "${1:-100}" ;;
  backup) command_backup "$@" ;;
  restore) command_restore "$@" ;;
  update) command_update ;;
  uninstall) command_uninstall "$@" ;;
  help|-h|--help) usage ;;
  version|--version) say "$VERSION" ;;
  *) usage; die "unknown command: $command" ;;
esac
